<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE hibernate-configuration PUBLIC
"-//Hibernate/Hibernate Configuration DTD 3.0//EN"
"http://hibernate.sourceforge.net/hibernate-configuration-3.0.dtd">
<hibernate-configuration>
<session-factory>

    <property name="hibernate.connection.driver_class">com.mysql.cj.jdbc.Driver</property>
        <property name="hibernate.connection.url">jdbc:mysql://localhost:3306/mydb</property>
        <property name="hibernate.connection.username">root</property>
        <property name="hibernate.connection.password">root1234</property>
        <property name="hibernate.hbm2ddl.auto">update</property>
<mapping resource="org/techno/sturent/admin.hbm.xml"/>
<mapping resource="org/techno/sturent/OrderProduct.hbm.xml"/>
<mapping resource="org/techno/sturent/feedback.hbm.xml"/>
<mapping resource="org/techno/sturent/StudentSignup.hbm.xml"/>
<mapping resource="org/techno/sturent/Complain.hbm.xml"/>
<mapping resource="org/techno/sturent/Auth.hbm.xml"/>
</session-factory>
</hibernate-configuration>