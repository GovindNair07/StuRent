<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE hibernate-mapping PUBLIC
"-//Hibernate/Hibernate Mapping DTD 3.0//EN"
"http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">

<hibernate-mapping package="org.techno.sturent">
<class name="OrderProduct" table="OrderProduct">
    <id name="orderid">
            <generator class="native"/>
        </id>
    <property name="studentid" column="studentid"/>
    <property name="productname" column="productname"/>
    <property name="quantity" column="quantity"/>
    <property name="price" column="price"/>
    <property name="address" column="address"/>
    <property name="Contact" column="Contact"/>

</class>
</hibernate-mapping>